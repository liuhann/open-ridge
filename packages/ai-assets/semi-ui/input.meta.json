{
  "name": "Input",
  "title": "输入框",
  "icon": "data:image/svg+xml;base64,",
  "description": "基础输入框组件，支持文本、密码等类型，提供前后置标签、清除按钮、校验状态、尺寸等常用配置",
  "tags": [
    "输入框",
    "表单",
    "文本输入",
    "密码框"
  ],
  "category": "表单组件",
  "version": "1.0.0",
  "author": "",
  "visualConfig": {
    "thumbnail": "",
    "preferredWidth": 280,
    "preferredHeight": 32,
    "resizable": true,
    "aspectRatio": "no"
  },
  "properties": [
    {
      "name": "value",
      "description": "输入框内容",
      "label": "输入内容",
      "type": "string",
      "defaultValue": ""
    },
    {
      "name": "defaultValue",
      "description": "输入框默认内容",
      "label": "默认内容",
      "type": "string",
      "defaultValue": ""
    },
    {
      "name": "type",
      "description": "input 类型，同原生 input",
      "label": "输入框类型",
      "control": "select",
      "type": "string",
      "options": [
        { "label": "文本", "value": "text" },
        { "label": "密码", "value": "password" }
      ],
      "defaultValue": "text"
    },
    {
      "name": "mode",
      "description": "输入框模式",
      "label": "模式",
      "control": "select",
      "type": "string",
      "options": [
        { "label": "默认", "value": "" },
        { "label": "密码", "value": "password" }
      ],
      "defaultValue": ""
    },
    {
      "name": "size",
      "description": "输入框大小",
      "label": "尺寸",
      "control": "select",
      "type": "string",
      "options": [
        { "label": "大", "value": "large" },
        { "label": "默认", "value": "default" },
        { "label": "小", "value": "small" }
      ],
      "defaultValue": "default"
    },
    {
      "name": "disabled",
      "description": "是否禁用",
      "label": "禁用",
      "control": "boolean",
      "type": "boolean",
      "defaultValue": false
    },
    {
      "name": "borderless",
      "description": "无边框模式",
      "label": "无边框",
      "control": "boolean",
      "type": "boolean",
      "defaultValue": false
    },
    {
      "name": "showClear",
      "description": "是否显示清除按钮",
      "label": "可清除",
      "control": "boolean",
      "type": "boolean",
      "defaultValue": false
    },
    {
      "name": "hideSuffix",
      "description": "清除按钮与后缀并存时隐藏后缀",
      "label": "隐藏后缀",
      "control": "boolean",
      "type": "boolean",
      "defaultValue": false
    },
    {
      "name": "validateStatus",
      "description": "校验状态",
      "label": "校验状态",
      "control": "select",
      "type": "string",
      "options": [
        { "label": "默认", "value": "default" },
        { "label": "错误", "value": "error" },
        { "label": "警告", "value": "warning" }
      ],
      "defaultValue": "default"
    },
    {
      "name": "composition",
      "description": "是否开启输入法优化模式",
      "label": "输入法优化",
      "control": "boolean",
      "type": "boolean",
      "defaultValue": false
    },
    {
      "name": "preventScroll",
      "description": "focus时是否禁止滚动",
      "label": "禁止滚动",
      "control": "boolean",
      "type": "boolean",
      "defaultValue": false
    },
    {
      "name": "aria-label",
      "description": "无障碍标签",
      "label": "ARIA 标签",
      "type": "string",
      "defaultValue": ""
    },
    {
      "name": "aria-required",
      "description": "是否必填",
      "label": "ARIA 必填",
      "type": "string",
      "defaultValue": ""
    },
    {
      "name": "className",
      "description": "自定义类名",
      "label": "类名",
      "type": "string",
      "defaultValue": ""
    },
    {
      "name": "placeholder",
      "description": "输入框提示文字",
      "label": "提示文字",
      "type": "string",
      "defaultValue": "请输入"
    }
  ],
  "events": [
    {
      "name": "onChange",
      "description": "内容变化时触发",
      "label": "内容变化"
    },
    {
      "name": "onFocus",
      "description": "获得焦点时触发",
      "label": "获得焦点"
    },
    {
      "name": "onBlur",
      "description": "失去焦点时触发",
      "label": "失去焦点"
    },
    {
      "name": "onClear",
      "description": "点击清除按钮时触发",
      "label": "点击清除"
    },
    {
      "name": "onEnterPress",
      "description": "按下回车时触发",
      "label": "回车事件"
    },
    {
      "name": "onKeyDown",
      "description": "按键按下时触发",
      "label": "按键按下"
    },
    {
      "name": "onKeyUp",
      "description": "按键抬起时触发",
      "label": "按键抬起"
    },
    {
      "name": "onCompositionStart",
      "description": "输入法开始 composing",
      "label": "输入法开始"
    },
    {
      "name": "onCompositionEnd",
      "description": "输入法结束 composing",
      "label": "输入法结束"
    }
  ]
}