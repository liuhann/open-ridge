{
  "name": "Carousel",
  "title": "走马灯",
  "icon": "svgs/carousel.svg",
  "description": "轮播走马灯，支持纯图片、纯文字、图片+标题轮播，可配置自动播放、动画、指示点、箭头",
  "tags": ["轮播", "走马灯", "图片轮播", "幻灯片", "展示组件"],
  "category": "展示组件",
  "version": "1.0.0",
  "visualConfig": {
    "preferredWidth": 800,
    "preferredHeight": 400,
    "resizable": true,
    "aspectRatio": "no"
  },
  "properties": [
    {
      "name": "slides",
      "label": "轮播内容",
      "description": "数组格式：[{ title: 标题, src: 图片地址 }]",
      "control": "json",
      "type": "array",
      "defaultValue": [
        { "title": "幻灯片 1", "src": "" },
        { "title": "幻灯片 2", "src": "" }
      ]
    },
    {
      "name": "effect",
      "label": "切换动画",
      "control": "select",
      "options": [{"label":"滚动","value":"scrollx"},{"label":"渐变","value":"fade"}],
      "defaultValue": "scrollx"
    },
    {
      "name": "autoplay",
      "label": "自动播放",
      "control": "boolean",
      "defaultValue": false
    },
    {
      "name": "autoplaySpeed",
      "label": "自动播放间隔(ms)",
      "type": "number",
      "defaultValue": 3000
    },
    {
      "name": "dots",
      "label": "显示指示点",
      "control": "boolean",
      "defaultValue": true
    },
    {
      "name": "arrows",
      "label": "显示箭头",
      "control": "boolean",
      "defaultValue": false
    },
    {
      "name": "infinite",
      "label": "无限循环",
      "control": "boolean",
      "defaultValue": true
    },
    {
      "name": "draggable",
      "label": "允许拖拽",
      "control": "boolean",
      "defaultValue": false
    },
    {
      "name": "adaptiveHeight",
      "label": "高度自适应",
      "control": "boolean",
      "defaultValue": false
    },
    {
      "name": "dotPlacement",
      "label": "指示点位置",
      "control": "select",
      "options": [{"label":"顶部","value":"top"},{"label":"底部","value":"bottom"},{"label":"左侧","value":"start"},{"label":"右侧","value":"end"}],
      "defaultValue": "bottom"
    },
    {
      "name": "speed",
      "label": "动画时长(ms)",
      "type": "number",
      "defaultValue": 500
    },
    {
      "name": "width",
      "label": "宽度",
      "type": "number",
      "hidden": true
    },
    {
      "name": "height",
      "label": "高度",
      "type": "number",
      "hidden": true
    }
  ],
  "events": [
    { "name": "afterChange", "label": "切换完成" }
  ]
}