{
  "name": "Select",
  "title": "选择器",
  "icon": "svgs/select.svg",
  "description": "下拉选择器，支持单选、多选、标签、搜索、清除等核心选择功能",
  "tags": [
    "选择",
    "下拉",
    "单选",
    "多选",
    "表单"
  ],
  "category": "表单组件",
  "version": "1.0.0",
  "author": "ridge-antd",
  "visualConfig": {
    "preferredWidth": 280,
    "preferredHeight": 36,
    "resizable": true,
    "aspectRatio": "no"
  },
  "properties": [
    {
      "name": "value",
      "label": "选中值",
      "description": "当前选中的条目",
      "type": "string",
      "defaultValue": ""
    },
    {
      "name": "options",
      "label": "选项配置",
      "description": "数据化配置下拉选项 { label, value }",
      "control": "json",
      "type": "array",
      "defaultValue": [
        { "label": "选项一", "value": "1" },
        { "label": "选项二", "value": "2" },
        { "label": "选项三", "value": "3" }
      ]
    },
    {
      "name": "placeholder",
      "label": "提示文字",
      "type": "string",
      "defaultValue": "请选择"
    },
    {
      "name": "allowClear",
      "label": "允许清除",
      "description": "是否显示清除按钮",
      "control": "boolean",
      "type": "boolean",
      "defaultValue": false
    },
    {
      "name": "showSearch",
      "label": "可搜索",
      "description": "是否支持搜索过滤选项",
      "control": "boolean",
      "type": "boolean",
      "defaultValue": false
    },
    {
      "name": "disabled",
      "label": "禁用",
      "description": "是否禁用选择器",
      "control": "boolean",
      "type": "boolean",
      "defaultValue": false
    },
    {
      "name": "size",
      "label": "组件大小",
      "control": "select",
      "type": "string",
      "options": [
        { "label": "大", "value": "large" },
        { "label": "中", "value": "medium" },
        { "label": "小", "value": "small" }
      ],
      "defaultValue": "medium"
    },
    {
      "name": "variant",
      "label": "样式形态",
      "control": "select",
      "type": "string",
      "options": [
        { "label": "描边", "value": "outlined" },
        { "label": "无边框", "value": "borderless" },
        { "label": "填充", "value": "filled" },
        { "label": "下划线", "value": "underlined" }
      ],
      "defaultValue": "outlined"
    },
    {
      "name": "status",
      "label": "校验状态",
      "control": "select",
      "type": "string",
      "options": [
        { "label": "错误", "value": "error" },
        { "label": "警告", "value": "warning" }
      ],
      "defaultValue": ""
    }
  ],
  "events": [
    {
      "name": "onChange",
      "label": "值变化",
      "description": "选中选项或值变化时触发，返回 value 和 option"
    }
  ]
}