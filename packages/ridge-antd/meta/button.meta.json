{
  "name": "Button",
  "title": "按钮",
  "icon": "svgs/button.svg",
  "description": "用于开始一个即时操作，支持不同类型、尺寸、状态。",
  "tags": [
    "按钮",
    "交互",
    "基础组件"
  ],
  "category": "基础组件",
  "version": "1.0.0",
  "author": "ridge-ui",
  "visualConfig": {
    "preferredWidth": 120,
    "preferredHeight": 40,
    "resizable": true,
    "aspectRatio": "no"
  },
  "properties": [
    {
      "name": "children",
      "description": "按钮上显示的文字",
      "label": "按钮文字",
      "type": "string",
      "defaultValue": "按钮"
    },
    {
      "name": "type",
      "description": "设置按钮类型，当设置 variant 与 color 时以后者为准",
      "label": "按钮类型",
      "control": "radiogroup",
      "type": "string",
      "options": [
        {
          "label": "默认",
          "value": "default"
        },
        {
          "label": "主要",
          "value": "primary"
        },
        {
          "label": "虚线",
          "value": "dashed"
        },
        {
          "label": "链接",
          "value": "link"
        },
        {
          "label": "文字",
          "value": "text"
        }
      ],
      "defaultValue": "default"
    },
    {
      "name": "variant",
      "description": "设置按钮的变体样式",
      "label": "按钮变体",
      "control": "select",
      "type": "string",
      "options": [
        {
          "label": "outline",
          "value": "outlined"
        },
        {
          "label": "dashed",
          "value": "dashed"
        },
        {
          "label": "solid",
          "value": "solid"
        },
        {
          "label": "filled",
          "value": "filled"
        },
        {
          "label": "text",
          "value": "text"
        },
        {
          "label": "link",
          "value": "link"
        }
      ],
      "defaultValue": ""
    },
    {
      "name": "shape",
      "description": "设置按钮形状",
      "label": "按钮形状",
      "control": "radiogroup",
      "type": "string",
      "options": [
        {
          "label": "默认",
          "value": "default"
        },
        {
          "label": "圆形",
          "value": "circle"
        },
        {
          "label": "圆角",
          "value": "round"
        }
      ],
      "defaultValue": "default"
    },
    {
      "name": "size",
      "description": "设置按钮大小",
      "label": "按钮尺寸",
      "control": "radiogroup",
      "type": "string",
      "options": [
        {
          "label": "大",
          "value": "large"
        },
        {
          "label": "中",
          "value": "medium"
        },
        {
          "label": "小",
          "value": "small"
        }
      ],
      "defaultValue": "medium"
    },
    {
      "name": "disabled",
      "description": "设置按钮失效状态",
      "label": "禁用",
      "control": "boolean",
      "type": "boolean",
      "defaultValue": false
    },
    {
      "name": "ghost",
      "description": "幽灵属性，使按钮背景透明",
      "label": "透明背景",
      "control": "boolean",
      "type": "boolean",
      "defaultValue": false
    },
    {
      "name": "block",
      "description": "将按钮宽度调整为其父宽度",
      "label": "宽度撑满父容器",
      "control": "boolean",
      "type": "boolean",
      "defaultValue": false
    },
    {
      "name": "loading",
      "description": "设置按钮载入状态",
      "label": "加载中",
      "control": "boolean",
      "type": "boolean",
      "defaultValue": false
    },
    {
      "name": "className",
      "description": "自定义 CSS 类名",
      "label": "自定义类名",
      "control": "className",
      "type": "array"
    },
    {
      "name": "classNames",
      "description": "自定义组件内部各语义化结构的 class",
      "label": "内部样式类名",
      "control": "json",
      "type": "object",
      "sample": {
        "button": "custom-button",
        "icon": "custom-icon"
      }
    },
    {
      "name": "styles",
      "description": "自定义组件内部各部分行内样式",
      "label": "内部样式",
      "control": "json",
      "type": "object",
      "sample": {
        "button": { "color": "red" },
        "icon": { "fontSize": "16px" }
      }
    }
  ],
  "events": [
    {
      "name": "onClick",
      "description": "点击按钮时触发",
      "label": "点击事件"
    }
  ]
}