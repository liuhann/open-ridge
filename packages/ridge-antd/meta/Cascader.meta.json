{
  "name": "Cascader",
  "title": "级联选择",
  "icon": "svgs/cascader.svg",
  "description": "级联选择器，用于多层级数据选择，支持单选、多选、搜索、清除等功能",
  "tags": [
    "级联",
    "选择",
    "表单",
    "多层级"
  ],
  "category": "表单组件",
  "version": "1.0.0",
  "author": "ridge-antd",
  "visualConfig": {
    "preferredWidth": 180,
    "preferredHeight": 36,
    "resizable": true,
    "aspectRatio": "no"
  },
  "properties": [
    {
      "name": "value",
      "label": "选中值",
      "description": "指定选中项",
      "type": "array",
      "defaultValue": []
    },
    {
      "name": "options",
      "label": "选项数据",
      "description": "可选项数据源，支持多层级 children",
      "control": "json",
      "type": "array",
      "defaultValue": [
        {
          "label": "浙江",
          "value": "zj",
          "children": [
            { "label": "杭州", "value": "hz" }
          ]
        }
      ]
    },
    {
      "name": "placeholder",
      "label": "占位提示",
      "description": "输入框占位文本",
      "type": "string",
      "defaultValue": "请选择"
    },
    {
      "name": "disabled",
      "label": "禁用",
      "description": "是否禁用",
      "control": "boolean",
      "type": "boolean",
      "defaultValue": false
    },
    {
      "name": "multiple",
      "label": "多选",
      "description": "支持多选节点",
      "control": "boolean",
      "type": "boolean",
      "defaultValue": false
    },
    {
      "name": "size",
      "label": "组件大小",
      "control": "select",
      "type": "string",
      "options": [
        { "label": "大", "value": "large" },
        { "label": "中", "value": "medium" },
        { "label": "小", "value": "small" }
      ],
      "defaultValue": "medium"
    },
    {
      "name": "variant",
      "label": "样式形态",
      "control": "select",
      "type": "string",
      "options": [
        { "label": "描边", "value": "outlined" },
        { "label": "无边框", "value": "borderless" },
        { "label": "填充", "value": "filled" },
        { "label": "下划线", "value": "underlined" }
      ],
      "defaultValue": "outlined"
    },
    {
      "name": "status",
      "label": "校验状态",
      "control": "select",
      "type": "string",
      "options": [
        { "label": "错误", "value": "error" },
        { "label": "警告", "value": "warning" }
      ],
      "defaultValue": ""
    }
  ],
  "events": [
    {
      "name": "onChange",
      "label": "选择变化",
      "description": "选择完成后的回调，返回 value 和选中项列表"
    }
  ]
}