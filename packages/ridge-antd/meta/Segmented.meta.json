{
  "name": "Segmented",
  "title": "分段控制器",
  "icon": "svgs/segmented.svg",
  "description": "分段选择器，支持横向/纵向排列、块级宽度、尺寸、形状配置，用于选项切换、筛选、状态切换",
  "tags": [
    "分段",
    "切换",
    "选项",
    "按钮组",
    "控制器"
  ],
  "category": "表单组件",
  "version": "1.0.0",
  "author": "ridge-antd",
  "visualConfig": {
    "preferredWidth": 198,
    "preferredHeight": 32,
    "resizable": true,
    "aspectRatio": "no"
  },
  "properties": [
    {
      "name": "options",
      "label": "选项配置",
      "description": "支持 string[] / { label, value }[]",
      "control": "json",
      "type": "array",
      "defaultValue": [
        { "label": "选项一", "value": "1" },
        { "label": "选项二", "value": "2" },
        { "label": "选项三", "value": "3" }
      ]
    },
    {
      "name": "value",
      "label": "当前选中值",
      "type": "string",
      "defaultValue": "1"
    },
    {
      "name": "block",
      "label": "父级宽度铺满",
      "control": "boolean",
      "type": "boolean",
      "defaultValue": false
    },
    {
      "name": "disabled",
      "label": "禁用",
      "control": "boolean",
      "type": "boolean",
      "defaultValue": false
    },
    {
      "name": "orientation",
      "label": "排列方向",
      "control": "select",
      "type": "string",
      "options": [
        { "label": "横向", "value": "horizontal" },
        { "label": "纵向", "value": "vertical" }
      ],
      "defaultValue": "horizontal"
    },
    {
      "name": "size",
      "label": "尺寸",
      "control": "select",
      "type": "string",
      "options": [
        { "label": "大", "value": "large" },
        { "label": "中", "value": "medium" },
        { "label": "小", "value": "small" }
      ],
      "defaultValue": "medium"
    },
    {
      "name": "shape",
      "label": "形状",
      "control": "select",
      "type": "string",
      "options": [
        { "label": "默认", "value": "default" },
        { "label": "圆角", "value": "round" }
      ],
      "defaultValue": "default"
    }
  ],
  "events": [
    {
      "name": "onChange",
      "label": "选中值变化",
      "description": "切换选项时触发，返回当前 value"
    }
  ]
}