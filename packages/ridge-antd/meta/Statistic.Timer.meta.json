{
  "name": "Statistic.Timer",
  "title": "计时",
  "icon": "svgs/statistic-timer.svg",
  "description": "倒计时/正计时组件，支持自定义格式、标题、前后缀、样式，支持完成回调与数值变化回调",
  "tags": [
    "计时",
    "倒计时",
    "正计时",
    "定时器",
    "时间展示"
  ],
  "category": "展示组件",
  "version": "1.0.0",
  "author": "ridge-antd",
  "visualConfig": {
    "preferredWidth": 240,
    "preferredHeight": 120,
    "resizable": true,
    "aspectRatio": "no"
  },
  "properties": [
    {
      "name": "type",
      "label": "计时类型",
      "control": "select",
      "type": "string",
      "options": [
        { "label": "倒计时", "value": "countdown" },
        { "label": "正计时", "value": "countup" }
      ],
      "defaultValue": "countdown"
    },
    {
      "name": "value",
      "label": "时间戳/毫秒数",
      "description": "倒计时：结束时间戳 / 正计时：开始时间戳",
      "type": "number",
      "defaultValue": 0
    },
    {
      "name": "format",
      "label": "时间格式",
      "type": "string",
      "defaultValue": "HH:mm:ss"
    },
    {
      "name": "title",
      "label": "标题",
      "type": "string",
      "defaultValue": ""
    },
    {
      "name": "prefix",
      "label": "前缀",
      "type": "string",
      "defaultValue": ""
    },
    {
      "name": "suffix",
      "label": "后缀",
      "type": "string",
      "defaultValue": ""
    },
    {
      "name": "valueStyle",
      "label": "数值样式",
      "type": "object",
      "defaultValue": {}
    }
  ],
  "events": [
    {
      "name": "onFinish",
      "label": "倒计时结束",
      "description": "倒计时完成时触发（正计时不生效）"
    },
    {
      "name": "onChange",
      "label": "时间变化",
      "description": "时间数值变化时触发，返回当前毫秒数"
    }
  ]
}