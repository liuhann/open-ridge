{
  "name": "Checkbox",
  "title": "切换选框",
  "icon": "svgs/checkbox.svg",
  "description": "单项复选框，支持选中、禁用、半选状态，用于开关、勾选、同意条款等场景",
  "tags": [
    "复选框",
    "勾选",
    "开关",
    "表单"
  ],
  "category": "表单组件",
  "version": "1.0.0",
  "author": "ridge-antd",
  "visualConfig": {
    "preferredWidth": 120,
    "preferredHeight": 32,
    "resizable": true,
    "aspectRatio": "no"
  },
  "properties": [
    {
      "name": "children",
      "description": "显示的文字",
      "label": "内容文字",
      "type": "string",
      "defaultValue": "切换选择"
    },
    {
      "name": "checked",
      "label": "是否选中",
      "description": "指定当前是否选中",
      "control": "boolean",
      "type": "boolean",
      "defaultValue": false
    },
    {
      "name": "disabled",
      "label": "禁用",
      "description": "是否禁用复选框",
      "control": "boolean",
      "type": "boolean",
      "defaultValue": false
    }
  ],
  "events": [
    {
      "name": "onChange",
      "label": "选中状态变化",
      "description": "勾选/取消勾选时触发，返回当前选中状态"
    }
  ]
}