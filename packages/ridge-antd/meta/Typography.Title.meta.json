{
  "name": "Typography.Title",
  "title": "标题",
  "icon": "svgs/typography-title.svg",
  "description": "用于页面标题展示，支持h1-h5等级、省略、可编辑、可复制、加粗、斜体等样式",
  "tags": [
    "标题",
    "文本",
    "展示组件"
  ],
  "category": "展示组件",
  "version": "1.0.0",
  "author": "ridge-antd",
  "visualConfig": {
    "preferredWidth": 168,
    "preferredHeight": 50,
    "resizable": true,
    "aspectRatio": "no"
  },
  "properties": [
    {
      "name": "children",
      "label": "标题内容",
      "description": "显示的标题文本内容",
      "type": "string",
      "defaultValue": "标题内容"
    },
    {
      "name": "level",
      "label": "标题等级",
      "description": "标题重要程度，对应h1-h5",
      "control": "select",
      "type": "string",
      "options": [
        {
          "label": "H1",
          "value": 1
        },
        {
          "label": "H2",
          "value": 2
        },
        {
          "label": "H3",
          "value": 3
        },
        {
          "label": "H4",
          "value": 4
        },
        {
          "label": "H5",
          "value": 5
        }
      ],
      "defaultValue": 1
    },
    {
      "name": "type",
      "label": "文本类型",
      "description": "设置文本状态类型",
      "control": "select",
      "type": "string",
      "options": [
        {
          "label": "次要",
          "value": "secondary"
        },
        {
          "label": "成功",
          "value": "success"
        },
        {
          "label": "警告",
          "value": "warning"
        },
        {
          "label": "危险",
          "value": "danger"
        }
      ],
      "defaultValue": ""
    },
    {
      "name": "disabled",
      "label": "禁用",
      "description": "是否禁用标题",
      "control": "boolean",
      "type": "boolean",
      "defaultValue": false
    },
    {
      "name": "italic",
      "label": "斜体",
      "description": "是否斜体显示",
      "control": "boolean",
      "type": "boolean",
      "defaultValue": false
    }
  ],
  "events": [
    {
      "name": "onClick",
      "description": "点击标题时触发",
      "label": "点击事件"
    }
  ]
}