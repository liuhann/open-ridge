{
  "name": "Tag",
  "title": "标签",
  "icon": "svgs/tag.svg",
  "description": "标签组件，用于标记、分类、状态展示，支持预设颜色、关闭按钮、图标、链接、变体样式",
  "tags": [
    "标签",
    "标记",
    "状态",
    "分类",
    "展示"
  ],
  "category": "展示组件",
  "version": "1.0.0",
  "author": "ridge-antd",
  "visualConfig": {
    "preferredWidth": 80,
    "preferredHeight": 32,
    "resizable": true,
    "aspectRatio": "no"
  },
  "properties": [
    {
      "name": "text",
      "label": "标签文字",
      "type": "string",
      "defaultValue": "标签"
    },
    {
      "name": "color",
      "label": "标签颜色",
      "control": "select",
      "type": "string",
      "options": [
        { "label": "magenta", "value": "magenta" },
        { "label": "red", "value": "red" },
        { "label": "volcano", "value": "volcano" },
        { "label": "orange", "value": "orange" },
        { "label": "gold", "value": "gold" },
        { "label": "lime", "value": "lime" },
        { "label": "green", "value": "green" },
        { "label": "cyan", "value": "cyan" },
        { "label": "blue", "value": "blue" },
        { "label": "geekblue", "value": "geekblue" },
        { "label": "purple", "value": "purple" }
      ],
      "defaultValue": ""
    },
    {
      "name": "variant",
      "label": "标签变体",
      "control": "select",
      "type": "string",
      "options": [
        { "label": "filled", "value": "filled" },
        { "label": "solid", "value": "solid" },
        { "label": "outlined", "value": "outlined" }
      ],
      "defaultValue": "filled"
    },
    {
      "name": "closeIcon",
      "label": "显示关闭按钮",
      "control": "boolean",
      "type": "boolean",
      "defaultValue": false
    },
    {
      "name": "disabled",
      "label": "禁用",
      "control": "boolean",
      "type": "boolean",
      "defaultValue": false
    }
  ],
  "events": [
    {
      "name": "onClose",
      "label": "关闭标签",
      "description": "点击关闭按钮时触发"
    }
  ]
}