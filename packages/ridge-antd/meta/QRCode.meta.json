{
  "name": "QRCode",
  "title": "二维码",
  "icon": "svgs/qrcode.svg",
  "description": "二维码生成组件，支持自定义内容、颜色、大小、中间图标、状态展示，用于链接、文本、信息扫码展示",
  "tags": [
    "二维码",
    "扫码",
    "生成",
    "展示",
    "链接"
  ],
  "category": "展示组件",
  "version": "1.0.0",
  "author": "ridge-antd",
  "visualConfig": {
    "preferredWidth": 160,
    "preferredHeight": 160,
    "resizable": true,
    "aspectRatio": "1:1"
  },
  "properties": [
    {
      "name": "value",
      "label": "二维码内容",
      "description": "扫描后解析的文本或链接",
      "type": "string",
      "defaultValue": "https://ant.design"
    },
    {
      "name": "size",
      "label": "二维码大小",
      "type": "number",
      "defaultValue": 160
    },
    {
      "name": "icon",
      "label": "中间图标",
      "description": "二维码中心图片地址",
      "type": "string",
      "defaultValue": ""
    },
    {
      "name": "iconSize",
      "label": "图标大小",
      "type": "number",
      "defaultValue": 40
    },
    {
      "name": "color",
      "label": "二维码颜色",
      "type": "color",
      "defaultValue": "#000000"
    },
    {
      "name": "bgColor",
      "label": "背景颜色",
      "type": "color",
      "defaultValue": "transparent"
    },
    {
      "name": "bordered",
      "label": "显示边框",
      "control": "boolean",
      "type": "boolean",
      "defaultValue": true
    },
    {
      "name": "marginSize",
      "label": "留白大小",
      "description": "二维码安静区边距",
      "type": "number",
      "defaultValue": 0
    },
    {
      "name": "errorLevel",
      "label": "纠错等级",
      "control": "select",
      "type": "string",
      "options": [
        { "label": "L", "value": "L" },
        { "label": "M", "value": "M" },
        { "label": "Q", "value": "Q" },
        { "label": "H", "value": "H" }
      ],
      "defaultValue": "M"
    },
    {
      "name": "status",
      "label": "状态",
      "control": "select",
      "type": "string",
      "options": [
        { "label": "正常", "value": "active" },
        { "label": "过期", "value": "expired" },
        { "label": "加载中", "value": "loading" },
        { "label": "已扫描", "value": "scanned" }
      ],
      "defaultValue": "active"
    }
  ],
  "events": []
}