{
  "name": "StackContainer",
  "title": "堆叠容器",
  "icon": "data:image/svg+xml;base64,",
  "description": "用于将多个组件层叠堆放在一起显示，实现主要内容之外的背景、前景、修饰等",
  "tags": [
    "容器",
    "前景",
    "背景",
    "修饰"
  ],
  "category": "容器",
  "version": "1.0.0",
  "author": "LiuHan",
  "visualConfig": {
    "thumbnail": "data:image/svg+xml;base64,",
    "preferredWidth": 360,
    "preferredHeight": 240,
    "resizable": true,
    "aspectRatio": "no"
  },
  "properties": [
    {
      "name": "children",
      "description": "容器内的子组件",
      "label": "子项",
      "control": "children",
      "type": "children",
      "hidden": true
    }
  ],
  "events": [
    {
      "name": "onMouseEnter",
      "description": "鼠标进入容器时触发",
      "label": "鼠标进入"
    },
    {
      "name": "onMouseLeave",
      "description": "鼠标离开容器时触发",
      "label": "鼠标离开"
    }
  ],
  "childStyles": [
    {
      "name": "showOnHover",
      "description": "是否只在悬停时显示（需要容器启用hoverable）",
      "label": "悬停显示",
      "control": "boolean",
      "type": "boolean",
      "defaultValue": false
    },
    {
      "name": "visible",
      "description": "子项是否可见",
      "label": "可见性",
      "control": "boolean",
      "type": "boolean",
      "defaultValue": true
    },
    {
      "name": "zIndex",
      "description": "子项的堆叠层级，数值越大显示越靠前",
      "label": "堆叠层级",
      "control": "number",
      "type": "number",
      "defaultValue": 0
    }
  ]
}