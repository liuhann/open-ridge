{
  "name": "RelativeContainer",
  "title": "相对定位容器",
  "icon": "data:image/svg+xml;base64,",
  "description": "相对定位布局容器，子组件可自由拖拽定位、自由摆放位置，支持绝对定位子项层级管理，适合画布、自定义排版、自由拖拽布局等场景",
  "tags": [
    "容器",
    "相对定位",
    "绝对定位",
    "自由布局",
    "拖拽布局"
  ],
  "category": "容器",
  "version": "1.0.0",
  "author": "LiuHan",
  "visualConfig": {
    "thumbnail": "供base64 图片，描述到页面后显示的样子，一般要额外提供",
    "preferredWidth": 360,
    "preferredHeight": 240,
    "resizable": true,
    "aspectRatio": "no"
  },
  "properties": [
    {
      "name": "overflow",
      "description": "是否隐藏超出容器范围的子项内容",
      "label": "溢出隐藏",
      "control": "boolean",
      "type": "boolean",
      "defaultValue": false
    },
    {
      "name": "children",
      "label": "子项",
      "control": "children",
      "type": "children",
      "hidden": true
    }
  ],
  "events": [],
  "childStyles": [
    {
      "name": "x",
      "description": "子项相对于容器的横向定位坐标（单位：像素）",
      "label": "X坐标",
      "control": "number",
      "type": "number",
      "defaultValue": 0
    },
    {
      "name": "y",
      "description": "子项相对于容器的纵向定位坐标（单位：像素）",
      "label": "Y坐标",
      "control": "number",
      "type": "number",
      "defaultValue": 0
    },
    {
      "name": "width",
      "description": "子项的宽度（单位：像素）",
      "label": "宽度",
      "control": "number",
      "type": "number"
    },
    {
      "name": "height",
      "description": "子项的高度（单位：像素）",
      "label": "高度",
      "control": "number",
      "type": "number"
    }
  ]
}