{
  "name": "Typography.Title",
  "title": "标题",
  "icon": "svgs/typography.svg",
  "description": "标题组件，用于页面标题、章节标题、卡片标题等，支持6级标题、可复制、省略、颜色样式、加粗等配置",
  "tags": [
    "标题",
    "文本",
    "展示",
    "排版"
  ],
  "category": "展示组件",
  "version": "1.0.0",
  "author": "LiuHan",
  "visualConfig": {
    "preferredWidth": 98,
    "preferredHeight": 52,
    "resizable": true,
    "aspectRatio": "no"
  },
  "properties": [
    {
      "name": "children",
      "description": "显示的文本内容",
      "label": "文本内容",
      "type": "string",
      "defaultValue": "标题1"
    },
    {
      "name": "heading",
      "description": "标题级别（1~6级）",
      "label": "标题级别",
      "control": "select",
      "type": "number",
      "options": [
        { "label": "H1 一级标题", "value": 1 },
        { "label": "H2 二级标题", "value": 2 },
        { "label": "H3 三级标题", "value": 3 },
        { "label": "H4 四级标题", "value": 4 },
        { "label": "H5 五级标题", "value": 5 },
        { "label": "H6 六级标题", "value": 6 }
      ],
      "defaultValue": 1
    },
    {
      "name": "copyable",
      "description": "是否允许点击复制文本",
      "label": "可复制",
      "control": "boolean",
      "type": "boolean",
      "defaultValue": false
    },
    {
      "name": "type",
      "description": "标题颜色类型",
      "label": "颜色类型",
      "control": "select",
      "type": "string",
      "options": [
        { "label": "主要", "value": "primary" },
        { "label": "次要", "value": "secondary" },
        { "label": "三级", "value": "tertiary" },
        { "label": "四级", "value": "quaternary" },
        { "label": "警告", "value": "warning" },
        { "label": "危险", "value": "danger" },
        { "label": "成功", "value": "success" }
      ],
      "defaultValue": "primary"
    }
  ],
  "events": []
}