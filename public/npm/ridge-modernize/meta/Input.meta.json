{
  "name": "Input",
  "title": "输入框",
  "icon": "svgs/input.svg",
  "description": "基于Bootstrap form-control封装文本输入框，支持多尺寸、密码/数字/邮箱等类型、只读、禁用、纯文本模式",
  "tags": [
    "输入框",
    "表单",
    "文本",
    "Bootstrap"
  ],
  "category": "表单组件",
  "version": "1.0.0",
  "author": "LiuHan",
  "visualConfig": {
    "preferredWidth": 136,
    "preferredHeight": 38,
    "resizable": true,
    "aspectRatio": "no"
  },
  "properties": [
    {
      "name": "value",
      "description": "输入框绑定值，通过onChange实现双向绑定",
      "label": "输入值",
      "type": "string",
      "defaultValue": ""
    },
    {
      "name": "placeholder",
      "description": "输入框空白提示文字",
      "label": "占位提示",
      "type": "string",
      "defaultValue": "请输入内容"
    },
    {
      "name": "type",
      "description": "输入框类型",
      "label": "输入类型",
      "control": "select",
      "type": "string",
      "options": [
        {
          "label": "文本 text",
          "value": "text"
        },
        {
          "label": "密码 password",
          "value": "password"
        },
        {
          "label": "数字 number",
          "value": "number"
        },
        {
          "label": "邮箱 email",
          "value": "email"
        },
        {
          "label": "手机号 tel",
          "value": "tel"
        }
      ],
      "defaultValue": "text"
    },
    {
      "name": "size",
      "description": "输入框尺寸大小",
      "label": "尺寸",
      "control": "select",
      "type": "string",
      "options": [
        {
          "label": "小号 sm",
          "value": "sm"
        },
        {
          "label": "中号 md",
          "value": "md"
        },
        {
          "label": "大号 lg",
          "value": "lg"
        }
      ],
      "defaultValue": "md"
    },
    {
      "name": "disabled",
      "description": "是否禁用输入框，禁止编辑",
      "label": "禁用",
      "type": "boolean",
      "defaultValue": false
    },
    {
      "name": "readOnly",
      "description": "只读模式，可复制不可修改",
      "label": "只读",
      "type": "boolean",
      "defaultValue": false
    },
    {
      "name": "plaintext",
      "description": "纯文本模式，无边框背景，仅展示文字",
      "label": "纯文本样式",
      "type": "boolean",
      "defaultValue": false
    }
  ],
  "events": [
    {
      "name": "onChange",
      "description": "输入内容变化时触发，参数：当前输入值、原生event",
      "label": "值变更"
    },
    {
      "name": "onFocus",
      "description": "输入框获得焦点触发",
      "label": "获得焦点"
    },
    {
      "name": "onBlur",
      "description": "输入框失去焦点触发",
      "label": "失去焦点"
    }
  ]
}