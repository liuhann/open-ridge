{
  "name": "FlexContainer",
  "title": "弹性容器",
  "icon": "icons/flex-container.svg",
  "description": "适合多个内容进行垂直或水平形式按固定或比例方式排列。通过弹性容器嵌套使用能实现很多复杂的功能，因为“弹性”的性质，弹性容器也可以满足“自适应”的布局诉求。",
  "tags": [
    "容器",
    "布局",
    "响应式"
  ],
  "category": "容器",
  "version": "1.0.0",
  "author": "LiuHan",
  "visualConfig": {
    "preferredWidth": 360,
    "preferredHeight": 240,
    "resizable": true,
    "aspectRatio": "no"
  },
  "properties": [
    {
      "name": "direction",
      "description": "主轴方向，决定子项的排列方向",
      "label": "排列方向",
      "control": "radiogroup",
      "type": "string",
      "options": [
        {
          "label": "横向",
          "value": "row"
        },
        {
          "label": "纵向",
          "value": "column"
        }
      ],
      "defaultValue": "row"
    },
    {
      "name": "justify",
      "description": "主轴上的对齐方式",
      "label": "排列对齐",
      "control": "radiogroup",
      "type": "string",
      "options": [
        {
          "label": "开始",
          "value": "flex-start"
        },
        {
          "label": "正中",
          "value": "center"
        },
        {
          "label": "结束",
          "value": "flex-end"
        },
        {
          "label": "两端对齐",
          "value": "space-between"
        },
        {
          "label": "均匀分布",
          "value": "space-evenly"
        }
      ],
      "defaultValue": "flex-start"
    },
    {
      "name": "alignItems",
      "description": "交叉轴上的对齐方式",
      "label": "交叉对齐",
      "control": "radiogroup",
      "type": "string",
      "options": [
        {
          "label": "起点",
          "value": "flex-start"
        },
        {
          "label": "正中",
          "value": "center"
        },
        {
          "label": "填充",
          "value": "stretch"
        },
        {
          "label": "终点",
          "value": "flex-end"
        }
      ],
      "defaultValue": "flex-start"
    },
    {
      "name": "flexWrap",
      "description": "是否允许子项换行显示",
      "label": "换行",
      "control": "boolean",
      "type": "boolean",
      "defaultValue": false
    },
    {
      "name": "gap",
      "description": "子项之间的间距（单位：像素）",
      "label": "间隔",
      "control": "number",
      "type": "number",
      "min": 0,
      "defaultValue": 8
    },
    {
      "name": "padding",
      "description": "容器内边距（单位：像素）",
      "label": "内间距",
      "control": "number",
      "type": "number",
      "min": 0,
      "defaultValue": 8
    },
    {
      "name": "children",
      "description": "容器内的子组件",
      "label": "子项",
      "control": "children",
      "type": "children",
      "hidden": true
    },
    {
      "name": "classList",
      "description": "为容器添加自定义 CSS 类名",
      "label": "自定义类名",
      "control": "classList",
      "type": "array"
    }
  ],
  "events": [
    {
      "name": "onClick",
      "description": "点击容器时触发",
      "label": "点击"
    },
    {
      "name": "onMouseDown",
      "description": "鼠标在容器上按下时触发",
      "label": "鼠标按下"
    }
  ],
  "childStyles": [
    {
      "name": "width",
      "description": "子项的宽度（单位：像素）",
      "label": "宽度",
      "control": "number",
      "type": "number"
    },
    {
      "name": "height",
      "description": "子项的高度（单位：像素）",
      "label": "高度",
      "control": "number",
      "type": "number"
    },
    {
      "name": "flex",
      "description": "子项在主轴上的伸缩比例（例如 1, 2, \"none\"）",
      "label": "弹性比例",
      "control": "text",
      "type": "string"
    },
    {
      "name": "autoWidth",
      "description": "子项在主轴上的伸缩比例（例如 1, 2, \"none\"）",
      "label": "宽度自动",
      "control": "boolean",
      "type": "boolean"
    },
    {
      "name": "autoHeight",
      "description": "子项在主轴上的伸缩比例（例如 1, 2, \"none\"）",
      "label": "高度自动",
      "control": "boolean",
      "type": "boolean"
    },
    {
      "name": "alignSelf",
      "description": "子项在交叉轴上是否拉伸填充",
      "label": "交叉填充",
      "control": "boolean",
      "type": "boolean"
    },
    {
      "name": "visible",
      "description": "子项是否可见",
      "label": "显示",
      "control": "boolean",
      "type": "boolean"
    }
  ]
}