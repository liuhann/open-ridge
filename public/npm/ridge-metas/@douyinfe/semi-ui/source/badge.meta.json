{
  "name": "Badge",
  "title": "徽标",
  "icon": "svgs/badge.svg",
  "description": "用于展示消息通知、数量标记、状态红点、角标等场景，支持数字、圆点、自定义内容",
  "tags": [
    "徽标",
    "红点",
    "通知",
    "角标",
    "基础组件"
  ],
  "category": "基础组件",
  "version": "1.0.0",
  "author": "LiuHan",
  "visualConfig": {
    "preferredWidth": 28,
    "preferredHeight": 28,
    "resizable": false,
    "aspectRatio": "no"
  },
  "properties": [
    {
      "name": "count",
      "description": "徽章展示的内容",
      "label": "显示数字/内容",
      "type": "number",
      "defaultValue": ""
    },
    {
      "name": "dot",
      "description": "不展示数字，只显示小圆点",
      "label": "小圆点模式",
      "control": "boolean",
      "type": "boolean",
      "defaultValue": false
    },
    {
      "name": "overflowCount",
      "description": "最大的展示数字值，超出显示 +",
      "label": "最大显示数值",
      "type": "number",
      "defaultValue": ""
    },
    {
      "name": "position",
      "description": "徽章相对于内容的位置",
      "label": "徽章位置",
      "control": "select",
      "type": "string",
      "options": [
        {
          "label": "左上",
          "value": "leftTop"
        },
        {
          "label": "左下",
          "value": "leftBottom"
        },
        {
          "label": "右上",
          "value": "rightTop"
        },
        {
          "label": "右下",
          "value": "rightBottom"
        }
      ],
      "defaultValue": "rightTop"
    },
    {
      "name": "theme",
      "description": "徽章主题风格",
      "label": "徽章主题",
      "control": "select",
      "type": "string",
      "options": [
        {
          "label": "实心",
          "value": "solid"
        },
        {
          "label": "浅色",
          "value": "light"
        },
        {
          "label": "反色",
          "value": "inverted"
        }
      ],
      "defaultValue": "solid"
    },
    {
      "name": "type",
      "description": "徽章类型/状态色",
      "label": "徽章类型",
      "control": "select",
      "type": "string",
      "options": [
        {
          "label": "主要",
          "value": "primary"
        },
        {
          "label": "次要",
          "value": "secondary"
        },
        {
          "label": "三级",
          "value": "tertiary"
        },
        {
          "label": "危险",
          "value": "danger"
        },
        {
          "label": "警告",
          "value": "warning"
        },
        {
          "label": "成功",
          "value": "success"
        }
      ],
      "defaultValue": "primary"
    },
    {
      "name": "className",
      "description": "外侧样式类名",
      "label": "外层类名",
      "type": "className"
    },
    {
      "name": "countClassName",
      "description": "内容区域样式类名",
      "label": "内容区类名",
      "type": "className"
    },
    {
      "name": "countStyle",
      "description": "徽章内容的内联样式",
      "label": "内容区样式",
      "type": "CSSProperties"
    }
  ],
  "events": []
}