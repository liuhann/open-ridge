{
  "name": "Select",
  "title": "下拉选择器",
  "icon": "svgs/select.svg",
  "description": "用于从选项列表中单选/多选的下拉选择组件，支持搜索、清除、远程搜索等常用功能",
  "tags": [
    "表单",
    "选择器",
    "下拉框"
  ],
  "category": "表单",
  "version": "1.0.0",
  "author": "RidgeUI",
  "visualConfig": {
    "preferredWidth": 280,
    "preferredHeight": 40,
    "resizable": true,
    "aspectRatio": "no"
  },
  "properties": [
    {
      "name": "value",
      "description": "当前选中的值，配合onChange实现双向绑定",
      "label": "选中值",
      "inputEvent": "onChange",
      "type": "string | number | array",
      "defaultValue": ""
    },
    {
      "name": "defaultValue",
      "description": "初始默认选中的值",
      "label": "默认值",
      "type": "string | number | array",
      "defaultValue": ""
    },
    {
      "name": "optionList",
      "description": "下拉选项列表，每项包含label和value",
      "label": "选项列表",
      "control": "json",
      "type": "array",
      "defaultValue": []
    },
    {
      "name": "placeholder",
      "description": "选择框默认提示文字",
      "label": "提示文字",
      "type": "string",
      "defaultValue": "请选择"
    },
    {
      "name": "disabled",
      "description": "是否禁用组件，禁用后无法交互",
      "label": "禁用",
      "control": "boolean",
      "type": "boolean",
      "defaultValue": false
    },
    {
      "name": "multiple",
      "description": "是否开启多选模式",
      "label": "多选",
      "control": "boolean",
      "type": "boolean",
      "defaultValue": false
    },
    {
      "name": "filter",
      "description": "是否开启搜索筛选功能",
      "label": "可搜索",
      "control": "boolean",
      "type": "boolean",
      "defaultValue": false
    },
    {
      "name": "allowCreate",
      "description": "是否允许创建新的选项，需配合搜索使用",
      "label": "允许创建",
      "control": "boolean",
      "type": "boolean",
      "defaultValue": false
    },
    {
      "name": "showClear",
      "description": "是否显示清除选中值的按钮",
      "label": "显示清除",
      "control": "boolean",
      "type": "boolean",
      "defaultValue": false
    },
    {
      "name": "showArrow",
      "description": "是否显示下拉箭头图标",
      "label": "显示箭头",
      "control": "boolean",
      "type": "boolean",
      "defaultValue": true
    },
    {
      "name": "autoFocus",
      "description": "是否自动获取焦点",
      "label": "自动聚焦",
      "control": "boolean",
      "type": "boolean",
      "defaultValue": false
    },
    {
      "name": "defaultOpen",
      "description": "是否默认展开下拉列表",
      "label": "默认展开",
      "control": "boolean",
      "type": "boolean",
      "defaultValue": false
    },
    {
      "name": "size",
      "description": "组件尺寸大小",
      "label": "尺寸",
      "control": "select",
      "type": "string",
      "options": [
        {
          "label": "默认",
          "value": "default"
        },
        {
          "label": "小",
          "value": "small"
        },
        {
          "label": "大",
          "value": "large"
        }
      ],
      "defaultValue": "default",
      "hidden": true
    },
    {
      "name": "borderless",
      "description": "是否开启无边框模式",
      "label": "无边框",
      "control": "boolean",
      "type": "boolean",
      "defaultValue": false
    },
    {
      "name": "maxTagCount",
      "description": "多选时最多显示的标签数量，超出显示+N",
      "label": "最大标签数",
      "control": "number",
      "type": "number",
      "min": 0,
      "defaultValue": 3
    },
    {
      "name": "max",
      "description": "多选时最多可选数量",
      "label": "最大可选数",
      "control": "number",
      "type": "number",
      "min": 0
    },
    {
      "name": "loading",
      "description": "下拉列表是否显示加载动画",
      "label": "加载中",
      "control": "boolean",
      "type": "boolean",
      "defaultValue": false
    },
    {
      "name": "position",
      "description": "下拉菜单展开位置",
      "label": "展开位置",
      "control": "select",
      "type": "string",
      "options": [
        {
          "label": "左下",
          "value": "bottomLeft"
        },
        {
          "label": "右下",
          "value": "bottomRight"
        },
        {
          "label": "左上",
          "value": "topLeft"
        },
        {
          "label": "右上",
          "value": "topRight"
        }
      ],
      "defaultValue": "bottomLeft"
    },
    {
      "name": "validateStatus",
      "description": "校验状态样式",
      "label": "校验状态",
      "control": "select",
      "type": "string",
      "options": [
        {
          "label": "默认",
          "value": "default"
        },
        {
          "label": "警告",
          "value": "warning"
        },
        {
          "label": "错误",
          "value": "error"
        }
      ],
      "defaultValue": "default"
    },
    {
      "name": "className",
      "description": "组件自定义CSS类名",
      "label": "自定义类名",
      "control": "className",
      "type": "string"
    },
    {
      "name": "style",
      "description": "组件内联样式",
      "label": "内联样式",
      "type": "CSSProperties"
    },
    {
      "name": "dropdownStyle",
      "description": "下拉弹层自定义样式",
      "label": "弹层样式",
      "type": "CSSProperties"
    }
  ],
  "events": [
    {
      "name": "onChange",
      "description": "选中值变化时触发",
      "label": "值改变"
    },
    {
      "name": "onSelect",
      "description": "选项被选中时触发",
      "label": "选中"
    },
    {
      "name": "onDeselect",
      "description": "多选取消选中时触发",
      "label": "取消选中"
    },
    {
      "name": "onClear",
      "description": "点击清除按钮时触发",
      "label": "清除"
    },
    {
      "name": "onSearch",
      "description": "搜索框内容变化时触发",
      "label": "搜索"
    },
    {
      "name": "onCreate",
      "description": "创建新选项时触发",
      "label": "创建选项"
    },
    {
      "name": "onDropdownVisibleChange",
      "description": "下拉列表展开/收起时触发",
      "label": "展开状态改变"
    },
    {
      "name": "onFocus",
      "description": "组件获取焦点时触发",
      "label": "获取焦点"
    },
    {
      "name": "onBlur",
      "description": "组件失去焦点时触发",
      "label": "失去焦点"
    },
    {
      "name": "onExceed",
      "description": "多选超出最大可选数量时触发",
      "label": "超出限制"
    }
  ]
}