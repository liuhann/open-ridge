{
  "name": "Descriptions",
  "title": "描述列表",
  "icon": "svgs/descriptions.svg",
  "description": "用于展示详情、表单结果、基础信息的描述列表组件，支持垂直/水平布局",
  "tags": [
    "展示",
    "详情",
    "描述",
    "布局"
  ],
  "category": "展示",
  "version": "1.0.0",
  "author": "RidgeUI",
  "visualConfig": {
    "preferredWidth": 540,
    "preferredHeight": 240,
    "resizable": true,
    "aspectRatio": "no"
  },
  "properties": [
    {
      "name": "data",
      "description": "描述列表数据源，包含 label、value、span",
      "label": "数据项",
      "control": "json",
      "type": "array",
      "sample": [
        { "label": "姓名", "value": "张三", "span": 1 },
        { "label": "年龄", "value": "28", "span": 1 },
        { "label": "地址", "value": "北京市朝阳区", "span": 2 }
      ],
      "defaultValue": []
    },
    {
      "name": "layout",
      "description": "列表布局模式",
      "label": "布局模式",
      "control": "select",
      "type": "string",
      "options": [
        { "label": "垂直", "value": "vertical" },
        { "label": "水平", "value": "horizontal" }
      ],
      "defaultValue": "vertical"
    },
    {
      "name": "align",
      "description": "描述列表对齐方式",
      "label": "对齐方式",
      "control": "select",
      "type": "string",
      "options": [
        { "label": "居中", "value": "center" },
        { "label": "两端对齐", "value": "justify" },
        { "label": "左对齐", "value": "left" },
        { "label": "朴素", "value": "plain" }
      ],
      "defaultValue": "center"
    },
    {
      "name": "row",
      "description": "是否双行显示（label 在上，value 在下）",
      "label": "双行显示",
      "control": "boolean",
      "type": "boolean",
      "defaultValue": false
    },
    {
      "name": "column",
      "description": "横向布局时，每行总列数",
      "label": "每行显示列数",
      "control": "number",
      "type": "number",
      "min": 1,
      "defaultValue": 3
    },
    {
      "name": "size",
      "description": "双行显示时的列表大小",
      "label": "尺寸大小",
      "control": "select",
      "type": "string",
      "options": [
        { "label": "小", "value": "small" },
        { "label": "中", "value": "medium" },
        { "label": "大", "value": "large" }
      ],
      "defaultValue": "medium"
    },
    {
      "name": "className",
      "description": "组件自定义 CSS 类名",
      "label": "自定义类名",
      "control": "className",
      "type": "string"
    },
    {
      "name": "style",
      "description": "组件内联样式",
      "label": "内联样式",
      "type": "CSSProperties"
    }
  ],
  "events": []
}