{
  "name": "Tag",
  "title": "标签",
  "icon": "svgs/tag.svg",
  "description": "用于标记、分类、展示关键词的轻量组件",
  "tags": [
    "标签",
    "标记",
    "分类"
  ],
  "category": "展示",
  "version": "1.0.0",
  "author": "LiuHan",
  "visualConfig": {
    "preferredWidth": 80,
    "preferredHeight": 32,
    "resizable": false,
    "aspectRatio": "no"
  },
  "properties": [
    {
      "name": "children",
      "description": "标签上显示的文字",
      "label": "内容",
      "type": "string",
      "defaultValue": "标签"
    },
    {
      "name": "closable",
      "description": "标签是否显示关闭按钮",
      "label": "可关闭",
      "control": "boolean",
      "type": "boolean",
      "defaultValue": false
    },
    {
      "name": "color",
      "description": "标签主题色",
      "label": "主题色",
      "control": "select",
      "type": "string",
      "options": [
        {
          "label": "灰色",
          "value": "grey"
        },
        {
          "label": "蓝色",
          "value": "blue"
        },
        {
          "label": "绿色",
          "value": "green"
        },
        {
          "label": "红色",
          "value": "red"
        },
        {
          "label": "橙色",
          "value": "orange"
        },
        {
          "label": "紫色",
          "value": "purple"
        },
        {
          "label": "青色",
          "value": "cyan"
        },
        {
          "label": "黄色",
          "value": "yellow"
        }
      ],
      "defaultValue": "grey"
    },
    {
      "name": "shape",
      "description": "标签形状",
      "label": "形状",
      "control": "radiogroup",
      "type": "string",
      "options": [
        {
          "label": "方形",
          "value": "square"
        },
        {
          "label": "圆角/圆形",
          "value": "circle"
        }
      ],
      "defaultValue": "square"
    },
    {
      "name": "size",
      "description": "标签尺寸",
      "label": "尺寸",
      "control": "select",
      "type": "string",
      "options": [
        {
          "label": "小",
          "value": "small"
        },
        {
          "label": "大",
          "value": "large"
        }
      ],
      "defaultValue": "small"
    },
    {
      "name": "type",
      "description": "标签样式类型",
      "label": "样式类型",
      "control": "select",
      "type": "string",
      "options": [
        {
          "label": "浅色",
          "value": "light"
        },
        {
          "label": "实心",
          "value": "solid"
        },
        {
          "label": "空心",
          "value": "ghost"
        }
      ],
      "defaultValue": "light"
    },
    {
      "name": "visible",
      "description": "标签是否可见",
      "label": "是否可见",
      "control": "boolean",
      "type": "boolean",
      "defaultValue": true
    },
    {
      "name": "width",
      "description": "组件宽度",
      "label": "宽度",
      "type": "number",
      "hidden": true
    },
    {
      "name": "height",
      "description": "组件高度",
      "label": "高度",
      "type": "number",
      "hidden": true
    }
  ],
  "events": [
    {
      "name": "onClick",
      "description": "点击标签时触发",
      "label": "点击"
    },
    {
      "name": "onClose",
      "description": "点击关闭按钮时触发",
      "label": "关闭"
    }
  ]
}