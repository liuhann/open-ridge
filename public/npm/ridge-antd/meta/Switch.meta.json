{
  "name": "Switch",
  "title": "开关",
  "icon": "svgs/switch.svg",
  "description": "开关组件，用于状态切换、开启/关闭功能",
  "tags": [
    "开关",
    "切换",
    "状态",
    "表单"
  ],
  "category": "表单组件",
  "version": "1.0.0",
  "author": "ridge-antd",
  "visualConfig": {
    "preferredWidth": 50,
    "preferredHeight": 32,
    "resizable": true,
    "aspectRatio": "no"
  },
  "properties": [
    {
      "name": "checked",
      "label": "是否选中",
      "description": "指定当前是否选中",
      "control": "boolean",
      "type": "boolean",
      "defaultValue": false
    },
    {
      "name": "disabled",
      "label": "禁用",
      "description": "是否禁用开关",
      "control": "boolean",
      "type": "boolean",
      "defaultValue": false
    },
    {
      "name": "loading",
      "label": "加载中",
      "description": "开关是否为加载状态",
      "control": "boolean",
      "type": "boolean",
      "defaultValue": false
    },
    {
      "name": "size",
      "label": "开关大小",
      "control": "select",
      "type": "string",
      "options": [
        { "label": "中等", "value": "medium" },
        { "label": "小型", "value": "small" }
      ],
      "defaultValue": "medium"
    }
  ],
  "events": [
    {
      "name": "onChange",
      "label": "状态变化",
      "description": "开关状态改变时触发，返回最新状态"
    }
  ]
}