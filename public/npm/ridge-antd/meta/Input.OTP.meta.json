{
  "name": "Input.OTP",
  "title": "验证码输入",
  "icon": "svgs/input-otp.svg",
  "description": "用于短信验证码、邮箱验证码等一次性密码输入，支持多格输入、格式化、掩码",
  "tags": [
    "验证码",
    "OTP",
    "输入",
    "表单"
  ],
  "category": "表单组件",
  "version": "1.0.0",
  "author": "ridge-antd",
  "visualConfig": {
    "preferredWidth": 210,
    "preferredHeight": 34,
    "resizable": true,
    "aspectRatio": "no"
  },
  "properties": [
    {
      "name": "value",
      "label": "输入内容",
      "description": "验证码输入框内容",
      "type": "string",
      "defaultValue": "398"
    },
    {
      "name": "length",
      "label": "输入位数",
      "description": "输入框格子数量",
      "type": "number",
      "defaultValue": 6
    },
    {
      "name": "size",
      "label": "组件大小",
      "control": "select",
      "type": "string",
      "options": [
        { "label": "小", "value": "small" },
        { "label": "中", "value": "medium" },
        { "label": "大", "value": "large" }
      ],
      "defaultValue": "medium"
    },
    {
      "name": "variant",
      "label": "样式形态",
      "control": "select",
      "type": "string",
      "options": [
        { "label": "描边", "value": "outlined" },
        { "label": "无边框", "value": "borderless" },
        { "label": "填充", "value": "filled" },
        { "label": "下划线", "value": "underlined" }
      ],
      "defaultValue": "outlined"
    },
    {
      "name": "mask",
      "label": "掩码显示",
      "description": "是否隐藏输入内容（显示为圆点）",
      "control": "boolean",
      "type": "boolean",
      "defaultValue": false
    },
    {
      "name": "status",
      "label": "校验状态",
      "control": "select",
      "type": "string",
      "options": [
        { "label": "错误", "value": "error" },
        { "label": "警告", "value": "warning" }
      ],
      "defaultValue": ""
    }
  ],
  "events": [
    {
      "name": "onChange",
      "label": "内容变化",
      "description": "输入内容变化时触发，返回完整字符串"
    },
    {
      "name": "onInput",
      "label": "实时输入",
      "description": "每一格输入变化时触发，返回数组"
    }
  ]
}