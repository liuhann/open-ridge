{
  "name": "Upload",
  "title": "文件上传",
  "icon": "svgs/upload.svg",
  "description": "本地文件选择组件，支持多选、预览、删除，文件列表可绑定变量供脚本使用（无服务器上传）",
  "tags": [
    "文件选择",
    "上传",
    "附件",
    "表单"
  ],
  "category": "表单组件",
  "version": "1.0.0",
  "author": "ridge-antd",
  "visualConfig": {
    "preferredWidth": 85,
    "preferredHeight": 34,
    "resizable": true,
    "aspectRatio": "no"
  },
  "properties": [
    {
      "name": "fileList",
      "label": "文件列表",
      "description": "已选择的文件列表（绑定到变量）",
      "type": "array",
      "inputEvent": "onChange",
      "defaultValue": []
    },
    {
      "name": "multiple",
      "label": "允许多文件",
      "description": "是否可以一次选择多个文件",
      "control": "boolean",
      "type": "boolean",
      "defaultValue": true
    },
    {
      "name": "listType",
      "label": "列表样式",
      "control": "select",
      "type": "string",
      "options": [
        { "label": "文本", "value": "text" },
        { "label": "图片", "value": "picture" },
        { "label": "卡片", "value": "picture-card" }
      ],
      "defaultValue": "text"
    },
    {
      "name": "showUploadList",
      "label": "显示文件列表",
      "control": "boolean",
      "type": "boolean",
      "defaultValue": true
    },
    {
      "name": "maxCount",
      "label": "最大上传数量",
      "description": "限制最多选择的文件数",
      "type": "number"
    },
    {
      "name": "accept",
      "label": "接受文件类型",
      "description": "限制选择的文件格式，例如：.png,.jpg,.pdf",
      "type": "string",
      "defaultValue": ""
    },
    {
      "name": "disabled",
      "label": "禁用",
      "description": "是否禁用文件选择",
      "control": "boolean",
      "type": "boolean",
      "defaultValue": false
    }
  ],
  "events": [
    {
      "name": "onChange",
      "label": "文件列表变化",
      "description": "选择、删除文件时触发，返回最新文件列表"
    },
    {
      "name": "onRemove",
      "label": "移除文件",
      "description": "删除文件时触发"
    }
  ]
}