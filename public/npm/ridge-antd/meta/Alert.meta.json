{
  "name": "Alert",
  "title": "警告提示",
  "icon": "svgs/alert.svg",
  "description": "页面展示警告、成功、错误、提示信息，支持标题、描述、图标、关闭按钮、顶部公告栏",
  "tags": [
    "警告",
    "提示",
    "消息",
    "通知",
    "公告"
  ],
  "category": "展示组件",
  "version": "1.0.0",
  "author": "ridge-antd",
  "visualConfig": {
    "preferredWidth": 260,
    "preferredHeight": 98,
    "resizable": true,
    "aspectRatio": "no"
  },
  "properties": [
    {
      "name": "title",
      "label": "标题",
      "type": "string",
      "defaultValue": "提示标题"
    },
    {
      "name": "description",
      "label": "描述内容",
      "type": "string",
      "defaultValue": "这是一段详细的提示描述信息"
    },
    {
      "name": "type",
      "label": "提示类型",
      "control": "select",
      "type": "string",
      "options": [
        { "label": "成功", "value": "success" },
        { "label": "消息", "value": "info" },
        { "label": "警告", "value": "warning" },
        { "label": "错误", "value": "error" }
      ],
      "defaultValue": "info"
    },
    {
      "name": "showIcon",
      "label": "显示图标",
      "control": "boolean",
      "type": "boolean",
      "defaultValue": false
    },
    {
      "name": "closable",
      "label": "可关闭",
      "control": "boolean",
      "type": "boolean",
      "defaultValue": false
    }
  ],
  "events": []
}