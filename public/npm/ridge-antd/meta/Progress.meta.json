{
  "name": "Progress",
  "title": "进度条",
  "icon": "svgs/progress.svg",
  "description": "进度条组件，支持线形、圆形、仪表盘三种样式，可配置百分比、状态、颜色、尺寸、是否显示文字",
  "tags": [
    "进度条",
    "加载",
    "百分比",
    "线形进度",
    "圆形进度"
  ],
  "category": "展示组件",
  "version": "1.0.0",
  "author": "ridge-antd",
  "visualConfig": {
    "preferredWidth": 126,
    "preferredHeight": 28,
    "resizable": true,
    "aspectRatio": "no"
  },
  "properties": [
    {
      "name": "type",
      "label": "进度条类型",
      "control": "select",
      "type": "string",
      "options": [
        { "label": "线形 line", "value": "line" },
        { "label": "圆形 circle", "value": "circle" },
        { "label": "仪表盘 dashboard", "value": "dashboard" }
      ],
      "defaultValue": "line"
    },
    {
      "name": "percent",
      "label": "百分比 0-100",
      "type": "number",
      "defaultValue": 36
    },
    {
      "name": "status",
      "label": "状态",
      "control": "select",
      "type": "string",
      "options": [
        { "label": "正常 normal", "value": "normal" },
        { "label": "成功 success", "value": "success" },
        { "label": "异常 exception", "value": "exception" },
        { "label": "动画 active (仅line)", "value": "active" }
      ],
      "defaultValue": "normal"
    },
    {
      "name": "size",
      "label": "尺寸",
      "control": "select",
      "type": "string",
      "options": [
        { "label": "small 小", "value": "small" },
        { "label": "medium 中", "value": "medium" }
      ],
      "defaultValue": "medium"
    },
    {
      "name": "showInfo",
      "label": "显示百分比文字",
      "control": "boolean",
      "type": "boolean",
      "defaultValue": true
    },
    {
      "name": "strokeColor",
      "label": "进度颜色",
      "type": "string",
      "defaultValue": "#1677FF"
    },
    {
      "name": "railColor",
      "label": "背景轨道颜色",
      "type": "string",
      "defaultValue": "#f5f5f5"
    },
    {
      "name": "strokeLinecap",
      "label": "线头样式",
      "control": "select",
      "type": "string",
      "options": [
        { "label": "round 圆角", "value": "round" },
        { "label": "butt 平头", "value": "butt" },
        { "label": "square 方头", "value": "square" }
      ],
      "defaultValue": "round"
    },
    {
      "name": "strokeWidth",
      "label": "进度条宽度 (circle/dashboard)",
      "type": "number",
      "defaultValue": 6
    }
  ],
  "events": []
}