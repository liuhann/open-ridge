{
  "name": "Typography.Text",
  "title": "文本",
  "icon": "svgs/typography-text.svg",
  "description": "用于展示普通文本、加粗、斜体、删除线、代码、标记等样式",
  "tags": [
    "文本",
    "展示",
    "基础组件"
  ],
  "category": "展示组件",
  "version": "1.0.0",
  "author": "ridge-ui",
  "visualConfig": {
    "preferredWidth": 64,
    "preferredHeight": 32,
    "resizable": true,
    "aspectRatio": "no"
  },
  "properties": [
    {
      "name": "children",
      "label": "文本内容",
      "description": "显示的文本内容",
      "type": "string",
      "defaultValue": "文本内容"
    },
    {
      "name": "type",
      "label": "文本类型",
      "description": "设置文本状态类型",
      "control": "select",
      "type": "string",
      "options": [
        {
          "label": "次要",
          "value": "secondary"
        },
        {
          "label": "成功",
          "value": "success"
        },
        {
          "label": "警告",
          "value": "warning"
        },
        {
          "label": "危险",
          "value": "danger"
        }
      ],
      "defaultValue": ""
    },
    {
      "name": "strong",
      "label": "加粗",
      "description": "是否加粗显示",
      "control": "boolean",
      "type": "boolean",
      "defaultValue": false
    },
    {
      "name": "italic",
      "label": "斜体",
      "description": "是否斜体显示",
      "control": "boolean",
      "type": "boolean",
      "defaultValue": false
    },
    {
      "name": "delete",
      "label": "删除线",
      "description": "是否添加删除线样式",
      "control": "boolean",
      "type": "boolean",
      "defaultValue": false
    },
    {
      "name": "underline",
      "label": "下划线",
      "description": "是否添加下划线样式",
      "control": "boolean",
      "type": "boolean",
      "defaultValue": false
    },
    {
      "name": "code",
      "label": "代码样式",
      "description": "是否添加代码样式",
      "control": "boolean",
      "type": "boolean",
      "defaultValue": false
    },
    {
      "name": "mark",
      "label": "标记高亮",
      "description": "是否添加标记高亮样式",
      "control": "boolean",
      "type": "boolean",
      "defaultValue": false
    },
    {
      "name": "keyboard",
      "label": "键盘样式",
      "description": "是否添加键盘样式",
      "control": "boolean",
      "type": "boolean",
      "defaultValue": false
    },
    {
      "name": "disabled",
      "label": "禁用",
      "description": "是否禁用文本",
      "control": "boolean",
      "type": "boolean",
      "defaultValue": false
    },
    {
      "name": "ellipsis",
      "label": "自动省略",
      "description": "内容超出宽度时自动显示省略号",
      "control": "boolean",
      "type": "boolean",
      "defaultValue": false
    },
    {
      "name": "className",
      "label": "自定义类名",
      "description": "自定义CSS类名",
      "control": "className",
      "type": "array"
    },
    {
      "name": "style",
      "label": "内联样式",
      "description": "组件内联样式",
      "type": "CSSProperties"
    },
    {
      "name": "width",
      "label": "宽度",
      "type": "number",
      "hidden": true
    },
    {
      "name": "height",
      "label": "高度",
      "type": "number",
      "hidden": true
    }
  ],
  "events": [
    {
      "name": "onClick",
      "description": "点击文本时触发",
      "label": "点击事件"
    }
  ]
}