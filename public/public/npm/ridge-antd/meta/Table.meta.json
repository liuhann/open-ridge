{
  "name": "Table",
  "title": "表格",
  "icon": "svgs/table.svg",
  "description": "基础数据表格，用于展示结构化数据，支持配置表头、数据源、边框、尺寸、分页、加载状态、单选/多选行选择",
  "tags": [
    "表格",
    "数据展示",
    "列表",
    "报表"
  ],
  "category": "展示组件",
  "version": "1.0.0",
  "author": "ridge-antd",
  "visualConfig": {
    "preferredWidth": 269,
    "preferredHeight": 168,
    "resizable": true,
    "aspectRatio": "no"
  },
  "properties": [
    {
      "name": "columns",
      "label": "表头配置",
      "description": "格式：[{ title: '列名', dataIndex: '字段', key: 'key' }]",
      "control": "json",
      "type": "array",
      "defaultValue": [
        { "title": "姓名", "dataIndex": "name", "key": "name" },
        { "title": "年龄", "dataIndex": "age", "key": "age" },
        { "title": "地址", "dataIndex": "address", "key": "address" }
      ]
    },
    {
      "name": "dataSource",
      "label": "表格数据",
      "description": "格式：[{ id: 1, name: '张三', age: 18, address: '...' }]",
      "control": "json",
      "type": "array",
      "defaultValue": [
        { "id": 1, "name": "张三", "age": 18, "address": "北京市朝阳区" },
        { "id": 2, "name": "李四", "age": 25, "address": "上海市浦东新区" }
      ]
    },
    {
      "name": "rowKey",
      "label": "行唯一标识",
      "type": "string",
      "defaultValue": "id"
    },
    {
      "name": "bordered",
      "label": "显示边框",
      "control": "boolean",
      "type": "boolean",
      "defaultValue": false
    },
    {
      "name": "size",
      "label": "表格尺寸",
      "control": "select",
      "type": "string",
      "options": [
        { "label": "大", "value": "large" },
        { "label": "中", "value": "medium" },
        { "label": "小", "value": "small" }
      ],
      "defaultValue": "large"
    },
    {
      "name": "loading",
      "label": "加载中",
      "control": "boolean",
      "type": "boolean",
      "defaultValue": false
    },
    {
      "name": "pagination",
      "label": "显示分页",
      "control": "boolean",
      "type": "boolean",
      "defaultValue": false
    },
    {
      "name": "showHeader",
      "label": "显示表头",
      "control": "boolean",
      "type": "boolean",
      "defaultValue": true
    },
    {
      "name": "selectionType",
      "label": "行选择类型",
      "description": "关闭/单选/多选",
      "control": "select",
      "type": "string",
      "options": [
        { "label": "关闭选择", "value": "none" },
        { "label": "单选", "value": "radio" },
        { "label": "多选", "value": "checkbox" }
      ],
      "defaultValue": "none"
    },
    {
      "name": "disabledRowField",
      "label": "行禁用字段",
      "description": "指定数据中用于禁用选择的字段名，示例：disabled",
      "type": "string",
      "defaultValue": ""
    },
    {
      "name": "width",
      "label": "宽度",
      "type": "number",
      "hidden": true
    },
    {
      "name": "height",
      "label": "高度",
      "type": "number",
      "hidden": true
    }
  ],
  "events": [
    {
      "name": "onRowSelect",
      "label": "行选中变更",
      "description": "行选择改变时触发，参数：选中key数组、选中行数据数组"
    }
  ]
}