{
  "name": "Upload",
  "title": "文件上传",
  "icon": "svgs/upload.svg",
  "description": "本地文件选择组件，支持按钮、拖拽、图片卡片三种形态，仅支持单选，文件可直接绑定到变量（无服务器上传）",
  "tags": [
    "文件选择",
    "上传",
    "附件",
    "表单"
  ],
  "category": "表单组件",
  "version": "1.0.0",
  "author": "ridge-antd",
  "visualConfig": {
    "preferredWidth": 85,
    "preferredHeight": 34,
    "resizable": true,
    "aspectRatio": "no"
  },
  "properties": [
    {
      "name": "value",
      "label": "当前文件",
      "description": "已选择的单个文件（绑定到变量）",
      "type": "object",
      "defaultValue": null
    },
    {
      "name": "type",
      "label": "上传形态",
      "description": "上传组件的展示方式",
      "control": "select",
      "type": "string",
      "options": [
        { "label": "按钮", "value": "button" },
        { "label": "拖拽", "value": "drag" },
        { "label": "图片卡片", "value": "picture-card" }
      ],
      "defaultValue": "button"
    },
    {
      "name": "accept",
      "label": "接受文件类型",
      "description": "限制选择的文件格式，例如：.png,.jpg,.pdf",
      "type": "string",
      "defaultValue": ""
    },
    {
      "name": "disabled",
      "label": "禁用",
      "description": "是否禁用文件选择",
      "control": "boolean",
      "type": "boolean",
      "defaultValue": false
    }
  ],
  "events": [
    {
      "name": "onChange",
      "label": "文件变化",
      "description": "选择或删除文件时触发"
    }
  ]
}