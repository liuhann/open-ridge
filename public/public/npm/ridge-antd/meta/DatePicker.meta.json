{
  "name": "DatePicker",
  "title": "日期选择器",
  "icon": "svgs/date-picker.svg",
  "description": "日期选择器，支持日期、周、月、季度、年份选择，用于表单时间选择场景",
  "tags": [
    "日期",
    "选择",
    "时间",
    "表单"
  ],
  "category": "表单组件",
  "version": "1.0.0",
  "author": "ridge-antd",
  "visualConfig": {
    "preferredWidth": 144,
    "preferredHeight": 36,
    "resizable": true,
    "aspectRatio": "no"
  },
  "properties": [
    {
      "name": "value",
      "label": "日期值",
      "description": "当前选中的日期",
      "type": "string",
      "defaultValue": ""
    },
    {
      "name": "picker",
      "label": "选择器类型",
      "control": "select",
      "type": "string",
      "options": [
        { "label": "日期", "value": "date" },
        { "label": "周", "value": "week" },
        { "label": "月", "value": "month" },
        { "label": "季度", "value": "quarter" },
        { "label": "年", "value": "year" }
      ],
      "defaultValue": "date"
    },
    {
      "name": "placeholder",
      "label": "提示文字",
      "type": "string",
      "defaultValue": "请选择"
    },
    {
      "name": "allowClear",
      "label": "允许清除",
      "control": "boolean",
      "type": "boolean",
      "defaultValue": true
    },
    {
      "name": "disabled",
      "label": "禁用",
      "control": "boolean",
      "type": "boolean",
      "defaultValue": false
    },
    {
      "name": "size",
      "label": "组件大小",
      "control": "select",
      "type": "string",
      "options": [
        { "label": "大", "value": "large" },
        { "label": "中", "value": "medium" },
        { "label": "小", "value": "small" }
      ],
      "defaultValue": "medium"
    },
    {
      "name": "variant",
      "label": "样式形态",
      "control": "select",
      "type": "string",
      "options": [
        { "label": "描边", "value": "outlined" },
        { "label": "无边框", "value": "borderless" },
        { "label": "填充", "value": "filled" },
        { "label": "下划线", "value": "underlined" }
      ],
      "defaultValue": "outlined"
    },
    {
      "name": "status",
      "label": "校验状态",
      "control": "select",
      "type": "string",
      "options": [
        { "label": "错误", "value": "error" },
        { "label": "警告", "value": "warning" }
      ],
      "defaultValue": ""
    }
  ],
  "events": [
    {
      "name": "onChange",
      "label": "日期变化",
      "description": "选中日期后触发，返回选中的日期值"
    }
  ]
}