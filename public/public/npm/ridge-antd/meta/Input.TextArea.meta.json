{
  "name": "Input.TextArea",
  "title": "文本域",
  "icon": "svgs/textarea.svg",
  "description": "多行文本输入框，支持自适应高度、清除、字数统计、校验状态等核心功能",
  "tags": [
    "输入",
    "多行文本",
    "文本域",
    "表单"
  ],
  "category": "表单组件",
  "version": "1.0.0",
  "author": "ridge-antd",
  "visualConfig": {
    "preferredWidth": 180,
    "preferredHeight": 56,
    "resizable": true,
    "aspectRatio": "no"
  },
  "properties": [
    {
      "name": "value",
      "label": "输入内容",
      "description": "输入框内容",
      "type": "string",
      "defaultValue": ""
    },
    {
      "name": "placeholder",
      "label": "提示文字",
      "type": "string",
      "defaultValue": "请输入内容"
    },
    {
      "name": "allowClear",
      "label": "允许清除",
      "description": "可以点击清除图标删除内容",
      "control": "boolean",
      "type": "boolean",
      "defaultValue": true
    },
    {
      "name": "showCount",
      "label": "显示字数",
      "description": "是否展示字数统计",
      "control": "boolean",
      "type": "boolean",
      "defaultValue": false
    },
    {
      "name": "maxLength",
      "label": "最大长度",
      "description": "输入内容最大长度",
      "type": "number"
    },
    {
      "name": "autoSize",
      "label": "自适应高度",
      "description": "自动根据内容调整高度",
      "control": "boolean",
      "type": "boolean",
      "defaultValue": false
    },
    {
      "name": "disabled",
      "label": "禁用",
      "description": "是否禁用状态",
      "control": "boolean",
      "type": "boolean",
      "defaultValue": false
    },
    {
      "name": "size",
      "label": "组件大小",
      "control": "select",
      "type": "string",
      "options": [
        { "label": "大", "value": "large" },
        { "label": "中", "value": "medium" },
        { "label": "小", "value": "small" }
      ],
      "defaultValue": "medium"
    },
    {
      "name": "variant",
      "label": "样式形态",
      "control": "select",
      "type": "string",
      "options": [
        { "label": "描边", "value": "outlined" },
        { "label": "无边框", "value": "borderless" },
        { "label": "填充", "value": "filled" },
        { "label": "下划线", "value": "underlined" }
      ],
      "defaultValue": "outlined"
    },
    {
      "name": "status",
      "label": "校验状态",
      "control": "select",
      "type": "string",
      "options": [
        { "label": "错误", "value": "error" },
        { "label": "警告", "value": "warning" }
      ],
      "defaultValue": ""
    }
  ],
  "events": [
    {
      "name": "onChange",
      "label": "内容变化",
      "description": "输入框内容变化时触发"
    },
    {
      "name": "onClear",
      "label": "清除内容",
      "description": "点击清除按钮时触发"
    }
  ]
}