{
  "name": "Spin",
  "title": "加载中",
  "icon": "svgs/spin.svg",
  "description": "加载动画组件，用于页面、模块、数据等待时展示，支持尺寸、描述、全屏、延迟、进度展示",
  "tags": [
    "加载",
    "等待",
    "动画",
    "loading",
    "全屏加载"
  ],
  "category": "展示组件",
  "version": "1.0.0",
  "author": "ridge-antd",
  "visualConfig": {
    "preferredWidth": 54,
    "preferredHeight": 60,
    "resizable": true,
    "aspectRatio": "no"
  },
  "properties": [
    {
      "name": "spinning",
      "label": "加载状态",
      "control": "boolean",
      "type": "boolean",
      "defaultValue": true
    },
    {
      "name": "size",
      "label": "尺寸",
      "control": "select",
      "type": "string",
      "options": [
        { "label": "small 小", "value": "small" },
        { "label": "medium 中", "value": "medium" },
        { "label": "large 大", "value": "large" }
      ],
      "defaultValue": "large"
    },
    {
      "name": "description",
      "label": "描述文案",
      "type": "string",
      "defaultValue": "加载中..."
    },
    {
      "name": "fullscreen",
      "label": "全屏遮罩",
      "control": "boolean",
      "type": "boolean",
      "defaultValue": false
    },
    {
      "name": "delay",
      "label": "延迟显示(ms)",
      "type": "number",
      "defaultValue": ""
    },
    {
      "name": "percent",
      "label": "进度百分比",
      "type": "number",
      "defaultValue": ""
    }
  ],
  "events": []
}